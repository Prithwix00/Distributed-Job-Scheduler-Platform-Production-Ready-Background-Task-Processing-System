# Copy to .env and adjust. docker-compose reads JWT_SECRET from here.

# Secret used to sign JWT access tokens. Change this in any real deployment.
JWT_SECRET=dev-secret-change-me

# --- Backend settings (consumed by app/config.py) ---
# For local (non-docker) dev against SQLite, uncomment:
# DATABASE_URL=sqlite:///./dev.db

# Postgres (docker-compose default is set in the compose file):
# DATABASE_URL=postgresql+psycopg2://scheduler:scheduler@localhost:5432/scheduler

# Worker / scheduler tuning
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_SECONDS=1.0
HEARTBEAT_TIMEOUT_SECONDS=30
SCHEDULER_TICK_SECONDS=2.0
